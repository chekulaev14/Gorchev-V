generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Типы номенклатуры (гибкая таблица вместо enum)
model ItemType {
  id    String @id // "material", "blank", "part", "subassembly", "product"
  name  String // "Сырьё", "Заготовка", "Деталь", "Подсборка", "Изделие"
  order Int    @default(0) // порядок сортировки
  color String @default("gray") // цвет для бейджа (amber, orange, blue, purple, emerald)
  items Item[]

  @@map("item_types")
}

// Единицы измерения
model Unit {
  id    String @id // "kg", "pcs", "m"
  name  String // "кг", "шт", "м"
  items Item[]

  @@map("units")
}

// Категории для группировки
model Category {
  id    String @id
  name  String
  image String?
  items Item[]

  @@map("categories")
}

// Позиция номенклатуры
model Item {
  id           String  @id
  name         String
  typeId       String  @map("type_id")
  unitId       String  @map("unit_id")
  categoryId   String? @map("category_id")
  description  String?
  images       String[] // массив URL фото
  pricePerUnit Float?  @map("price_per_unit")

  type     ItemType  @relation(fields: [typeId], references: [id])
  unit     Unit      @relation(fields: [unitId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id])

  // BOM связи
  childOf  BomEntry[] @relation("BomChild")
  parentOf BomEntry[] @relation("BomParent")

  // Складские движения
  stockMovements StockMovement[]

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at") // soft delete

  @@index([deletedAt])
  @@map("items")
}

// Связь "из чего состоит" (Bill of Materials)
model BomEntry {
  id       String @id @default(cuid())
  parentId String @map("parent_id")
  childId  String @map("child_id")
  quantity Float  // сколько единиц child нужно на 1 единицу parent

  parent Item @relation("BomParent", fields: [parentId], references: [id], onDelete: Cascade)
  child  Item @relation("BomChild", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@map("bom_entries")
}

// Рабочие (авторизация по PIN)
model Worker {
  id        String   @id @default(cuid())
  name      String
  pin       String   @unique
  role      String   @default("worker") // worker, warehouse, director
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  productionLogs ProductionLog[]

  @@map("workers")
}

// Журнал выработки
model ProductionLog {
  id           String   @id @default(cuid())
  workerId     String   @map("worker_id")
  itemId       String   @map("item_id")
  itemName     String   @map("item_name")
  quantity     Int
  pricePerUnit Float    @map("price_per_unit")
  total        Float
  createdAt    DateTime @default(now()) @map("created_at")

  worker Worker @relation(fields: [workerId], references: [id])

  @@index([workerId])
  @@index([createdAt])
  @@map("production_logs")
}

// Складские движения
model StockMovement {
  id          String   @id @default(cuid())
  type        String   // supplier_income, production_income, assembly_write_off, assembly_income, adjustment
  itemId      String   @map("item_id")
  quantity    Float
  performedBy String?  @map("performed_by")
  workerId    String?  @map("worker_id")
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")

  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId])
  @@index([createdAt])
  @@map("stock_movements")
}
